<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PYS.Client.ViewModels"
             x:Class="PYS.Client.Views.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Şifre Değiştir">

    <VerticalStackLayout Padding="40" Spacing="12" MaximumWidthRequest="420" HorizontalOptions="Center">
        <Label Text="Şifre Değiştir" FontSize="22" FontAttributes="Bold" />

        <Label Text="Mevcut Şifre" FontSize="12" />
        <Entry Text="{Binding CurrentPassword}" IsPassword="True" />

        <Label Text="Yeni Şifre (min 6)" FontSize="12" />
        <Entry Text="{Binding NewPassword}" IsPassword="True" />

        <Label Text="Yeni Şifre (Tekrar)" FontSize="12" />
        <Entry Text="{Binding ConfirmPassword}" IsPassword="True" />

        <Label Text="{Binding ErrorMessage}" TextColor="Red" FontSize="12"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
        <Label Text="{Binding SuccessMessage}" TextColor="Green" FontSize="12"
               IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotEmptyConverter}}" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">
            <Button Grid.Column="0" Text="İptal" Command="{Binding CancelCommand}"
                    BackgroundColor="LightGray" TextColor="Black" />
            <Button Grid.Column="1" Text="Kaydet" Command="{Binding SubmitCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
        </Grid>

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
    </VerticalStackLayout>
</ContentPage>
