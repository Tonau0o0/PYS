<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PYS.Client.ViewModels"
             xmlns:models="clr-namespace:PYS.Client.Models"
             x:Class="PYS.Client.Views.TasksPage"
             x:DataType="vm:TasksViewModel"
             Title="{Binding ProjectName}">

    <ContentPage.Resources>
        <Color x:Key="CardBg">#FFFFFF</Color>
        <Color x:Key="CardText">#1F2937</Color>
        <Color x:Key="CardSubText">#6B7280</Color>
        <Color x:Key="ColumnText">#111827</Color>

        <DataTemplate x:Key="TaskCardTemplate" x:DataType="models:TaskItem">
            <Border StrokeShape="RoundRectangle 8"
                    Stroke="#D1D5DB" StrokeThickness="1"
                    Margin="0,4" Padding="0"
                    BackgroundColor="{StaticResource CardBg}">
                <Border.GestureRecognizers>
                    <DragGestureRecognizer CanDrag="True"
                        DragStartingCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:TasksViewModel}}, Path=DragStartedCommand}"
                        DragStartingCommandParameter="{Binding .}" />
                    <DropGestureRecognizer AllowDrop="True"
                        DropCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:TasksViewModel}}, Path=DropResourceOnTaskCommand}"
                        DropCommandParameter="{Binding .}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="6,*">
                    <BoxView Grid.Column="0"
                             Color="{Binding AssigneeColor, Converter={StaticResource StringToColorConverter}}" />
                    <VerticalStackLayout Grid.Column="1" Padding="10" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding Title}" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource CardText}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="⋮" FontSize="18" FontAttributes="Bold"
                                    Padding="0" WidthRequest="32" HeightRequest="32"
                                    BackgroundColor="Transparent" TextColor="{StaticResource CardSubText}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TasksViewModel}}, Path=TaskMenuCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                        <Label Text="{Binding Description}" FontSize="11"
                               TextColor="{StaticResource CardSubText}"
                               LineBreakMode="TailTruncation" MaxLines="2"
                               IsVisible="{Binding Description, Converter={StaticResource StringNotEmptyConverter}}" />

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <Label Grid.Column="0" FontSize="10"
                                   TextColor="{StaticResource CardSubText}" VerticalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="🚩 " />
                                        <Span Text="{Binding Priority}" FontAttributes="Bold" />
                                        <Span Text="    " />
                                        <Span Text="📅 " />
                                        <Span Text="{Binding DueDate, StringFormat='{0:dd.MM.yyyy}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Border Grid.Column="1" WidthRequest="28" HeightRequest="28"
                                    StrokeShape="RoundRectangle 14" Stroke="Transparent"
                                    BackgroundColor="{Binding AssigneeColor, Converter={StaticResource StringToColorConverter}}"
                                    IsVisible="{Binding AssigneeUserName, Converter={StaticResource StringNotEmptyConverter}}">
                                <Grid>
                                    <Label Text="{Binding AssigneeUserName, Converter={StaticResource InitialsConverter}}"
                                           TextColor="White" FontSize="11" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Image Source="{Binding AssigneeAvatarUrl, Converter={StaticResource ApiUrlConverter}}"
                                           Aspect="AspectFill"
                                           IsVisible="{Binding AssigneeAvatarUrl, Converter={StaticResource StringNotEmptyConverter}}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </DataTemplate>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="↻ Yenile" Command="{Binding LoadCommand}" />
        <ToolbarItem Text="← Projeler" Command="{Binding BackCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="8" RowSpacing="8">
        <Label Grid.Row="0" Text="Görevleri sürükleyip kolonlar arasında taşıyabilirsin."
               FontSize="11" TextColor="Gray" Margin="4,0" />
        <Label Grid.Row="1" Text="{Binding ErrorMessage}" TextColor="Red" FontSize="12"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

        <ScrollView Grid.Row="2" Orientation="Horizontal">
            <HorizontalStackLayout Spacing="10" Padding="4">

                <!-- TODO -->
                <Border WidthRequest="280" StrokeShape="RoundRectangle 8" Padding="10"
                        Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="#F5F5F5">
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                            DropCommand="{Binding DropCommand}"
                            DropCommandParameter="Todo" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                            <BoxView Grid.Column="0" WidthRequest="10" HeightRequest="10" Color="#9E9E9E" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Todo" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource ColumnText}" Margin="6,0,0,0" />
                            <Label Grid.Column="2" Text="{Binding TodoColumn.Count}" FontSize="11"
                                   TextColor="{StaticResource CardSubText}" />
                        </Grid>
                        <ScrollView Grid.Row="1">
                            <CollectionView ItemsSource="{Binding TodoColumn}"
                                            ItemTemplate="{StaticResource TaskCardTemplate}"
                                            SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label Text="(boş — sürükleyip bırakabilirsin)" FontSize="11"
                                           TextColor="{StaticResource CardSubText}"
                                           HorizontalOptions="Center" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </ScrollView>
                        <Button Grid.Row="2" Text="+ Görev Ekle" FontSize="11"
                                BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                Command="{Binding NewTaskInStatusCommand}" CommandParameter="Todo" />
                    </Grid>
                </Border>

                <!-- IN PROGRESS -->
                <Border WidthRequest="280" StrokeShape="RoundRectangle 8" Padding="10"
                        Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="#FFF8E1">
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                            DropCommand="{Binding DropCommand}"
                            DropCommandParameter="InProgress" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                            <BoxView Grid.Column="0" WidthRequest="10" HeightRequest="10" Color="#FFC107" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="In Progress" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource ColumnText}" Margin="6,0,0,0" />
                            <Label Grid.Column="2" Text="{Binding InProgressColumn.Count}" FontSize="11"
                                   TextColor="{StaticResource CardSubText}" />
                        </Grid>
                        <ScrollView Grid.Row="1">
                            <CollectionView ItemsSource="{Binding InProgressColumn}"
                                            ItemTemplate="{StaticResource TaskCardTemplate}"
                                            SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label Text="(boş — sürükleyip bırakabilirsin)" FontSize="11"
                                           TextColor="{StaticResource CardSubText}"
                                           HorizontalOptions="Center" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </ScrollView>
                        <Button Grid.Row="2" Text="+ Görev Ekle" FontSize="11"
                                BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                Command="{Binding NewTaskInStatusCommand}" CommandParameter="InProgress" />
                    </Grid>
                </Border>

                <!-- IN REVIEW -->
                <Border WidthRequest="280" StrokeShape="RoundRectangle 8" Padding="10"
                        Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="#E3F2FD">
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                            DropCommand="{Binding DropCommand}"
                            DropCommandParameter="InReview" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                            <BoxView Grid.Column="0" WidthRequest="10" HeightRequest="10" Color="#2196F3" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="In Review" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource ColumnText}" Margin="6,0,0,0" />
                            <Label Grid.Column="2" Text="{Binding InReviewColumn.Count}" FontSize="11"
                                   TextColor="{StaticResource CardSubText}" />
                        </Grid>
                        <ScrollView Grid.Row="1">
                            <CollectionView ItemsSource="{Binding InReviewColumn}"
                                            ItemTemplate="{StaticResource TaskCardTemplate}"
                                            SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label Text="(boş — sürükleyip bırakabilirsin)" FontSize="11"
                                           TextColor="{StaticResource CardSubText}"
                                           HorizontalOptions="Center" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </ScrollView>
                        <Button Grid.Row="2" Text="+ Görev Ekle" FontSize="11"
                                BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                Command="{Binding NewTaskInStatusCommand}" CommandParameter="InReview" />
                    </Grid>
                </Border>

                <!-- DONE -->
                <Border WidthRequest="280" StrokeShape="RoundRectangle 8" Padding="10"
                        Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="#E8F5E9">
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                            DropCommand="{Binding DropCommand}"
                            DropCommandParameter="Done" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                            <BoxView Grid.Column="0" WidthRequest="10" HeightRequest="10" Color="#4CAF50" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Done" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource ColumnText}" Margin="6,0,0,0" />
                            <Label Grid.Column="2" Text="{Binding DoneColumn.Count}" FontSize="11"
                                   TextColor="{StaticResource CardSubText}" />
                        </Grid>
                        <ScrollView Grid.Row="1">
                            <CollectionView ItemsSource="{Binding DoneColumn}"
                                            ItemTemplate="{StaticResource TaskCardTemplate}"
                                            SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label Text="(boş — sürükleyip bırakabilirsin)" FontSize="11"
                                           TextColor="{StaticResource CardSubText}"
                                           HorizontalOptions="Center" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </ScrollView>
                        <Button Grid.Row="2" Text="+ Görev Ekle" FontSize="11"
                                BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                Command="{Binding NewTaskInStatusCommand}" CommandParameter="Done" />
                    </Grid>
                </Border>

                <!-- BLOCKED -->
                <Border WidthRequest="280" StrokeShape="RoundRectangle 8" Padding="10"
                        Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="#FFEBEE">
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                            DropCommand="{Binding DropCommand}"
                            DropCommandParameter="Blocked" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                            <BoxView Grid.Column="0" WidthRequest="10" HeightRequest="10" Color="#F44336" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Blocked" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource ColumnText}" Margin="6,0,0,0" />
                            <Label Grid.Column="2" Text="{Binding BlockedColumn.Count}" FontSize="11"
                                   TextColor="{StaticResource CardSubText}" />
                        </Grid>
                        <ScrollView Grid.Row="1">
                            <CollectionView ItemsSource="{Binding BlockedColumn}"
                                            ItemTemplate="{StaticResource TaskCardTemplate}"
                                            SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label Text="(boş — sürükleyip bırakabilirsin)" FontSize="11"
                                           TextColor="{StaticResource CardSubText}"
                                           HorizontalOptions="Center" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </ScrollView>
                        <Button Grid.Row="2" Text="+ Görev Ekle" FontSize="11"
                                BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                Command="{Binding NewTaskInStatusCommand}" CommandParameter="Blocked" />
                    </Grid>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- PROJE KAYNAKLARI PANELI (dosyalar + YouTube) -->
        <Border Grid.Row="3" HeightRequest="220" StrokeShape="RoundRectangle 8"
                Stroke="#D1D5DB" StrokeThickness="1" Padding="10" BackgroundColor="#FAFAFA"
                BindingContext="{Binding Resources}" x:DataType="vm:ResourcesViewModel">
            <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                        <Button Text="⬆" FontSize="13" Padding="8,2" BackgroundColor="LightGray" TextColor="Black"
                                IsVisible="{Binding IsInSubfolder}" Command="{Binding GoUpCommand}" />
                        <Label Text="📂" FontSize="14" VerticalOptions="Center" />
                        <Label Text="{Binding CurrentPathText}" FontAttributes="Bold" FontSize="13"
                               TextColor="{StaticResource ColumnText}" VerticalOptions="Center"
                               LineBreakMode="HeadTruncation" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="6">
                        <Button Text="+ Klasör" FontSize="11" Padding="8,4"
                                BackgroundColor="#F59E0B" TextColor="White" Command="{Binding NewFolderCommand}" />
                        <Button Text="+ Dosya" FontSize="11" Padding="8,4"
                                BackgroundColor="{StaticResource Primary}" TextColor="White" Command="{Binding AddFileCommand}" />
                        <Button Text="+ YouTube" FontSize="11" Padding="8,4"
                                BackgroundColor="#FF0000" TextColor="White" Command="{Binding AddYouTubeCommand}" />
                    </HorizontalStackLayout>
                </Grid>

                <CollectionView Grid.Row="1" ItemsSource="{Binding Resources}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="Henüz kaynak yok. Dosya veya YouTube linki ekle."
                               FontSize="12" TextColor="{StaticResource CardSubText}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProjectResourceItem">
                            <Border WidthRequest="160" StrokeShape="RoundRectangle 8"
                                    Stroke="#D1D5DB" StrokeThickness="1" Padding="0" BackgroundColor="White">
                                <Grid RowDefinitions="90,Auto,Auto" RowSpacing="2">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ResourcesViewModel}}, Path=OpenResourceCommand}"
                                            CommandParameter="{Binding .}" />
                                        <DragGestureRecognizer CanDrag="True"
                                            DragStartingCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:ResourcesViewModel}}, Path=DragStartingCommand}"
                                            DragStartingCommandParameter="{Binding .}" />
                                        <DropGestureRecognizer AllowDrop="True"
                                            DropCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:ResourcesViewModel}}, Path=DropOnFolderCommand}"
                                            DropCommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <!-- Önizleme -->
                                    <Grid Grid.Row="0" BackgroundColor="#111827">
                                        <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill"
                                               IsVisible="{Binding IsYouTube}" />
                                        <Label Text="{Binding Glyph}" FontSize="40" TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               IsVisible="{Binding IsYouTube, Converter={StaticResource InvertedBoolConverter}}" />
                                        <Label Text="▶" FontSize="30" TextColor="White" FontAttributes="Bold"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               IsVisible="{Binding IsYouTube}" />
                                        <Button Text="✕" FontSize="11" Padding="0" WidthRequest="26" HeightRequest="26"
                                                HorizontalOptions="End" VerticalOptions="Start" Margin="2"
                                                BackgroundColor="#80000000" TextColor="White"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ResourcesViewModel}}, Path=DeleteResourceCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>

                                    <Label Grid.Row="1" Text="{Binding Title}" FontSize="12" FontAttributes="Bold"
                                           Margin="8,4,8,0" LineBreakMode="TailTruncation" MaxLines="1"
                                           TextColor="{StaticResource CardText}" />
                                    <Label Grid.Row="2" Text="{Binding MetaText}" FontSize="10"
                                           Margin="8,0,8,8" TextColor="{StaticResource CardSubText}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
