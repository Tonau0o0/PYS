<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PYS.Client.ViewModels"
             xmlns:models="clr-namespace:PYS.Client.Models"
             x:Class="PYS.Client.Views.ProjectsPage"
             x:DataType="vm:ProjectsViewModel"
             Title="Projeler">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Yeni Proje" Command="{Binding NewProjectCommand}" />
        <ToolbarItem Text="Profil" Command="{Binding ProfileCommand}" />
        <ToolbarItem Text="Şifre" Command="{Binding ChangePasswordCommand}" />
        <ToolbarItem Text="Çıkış" Command="{Binding LogoutCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="12">
        <HorizontalStackLayout Grid.Row="0" Spacing="10">
            <Border WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" Stroke="Transparent"
                    VerticalOptions="Center"
                    BackgroundColor="{Binding CurrentColor, Converter={StaticResource StringToColorConverter}}">
                <Grid>
                    <Label Text="{Binding CurrentUserName, Converter={StaticResource InitialsConverter}}"
                           TextColor="White" FontSize="15" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                    <Image Source="{Binding CurrentAvatarUrl, Converter={StaticResource ApiUrlConverter}}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasAvatar}" />
                </Grid>
            </Border>
            <Label Text="{Binding GreetingText}" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,12,0,8">
            <Label Grid.Column="0" Text="Durum filtresi:" VerticalOptions="Center" />
            <Picker Grid.Column="1"
                    ItemsSource="{Binding StatusFilters}"
                    SelectedItem="{Binding SelectedStatus}"
                    Title="Tümü" />
        </Grid>

        <Label Grid.Row="2" Text="{Binding ErrorMessage}" TextColor="Red" FontSize="12"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

        <RefreshView Grid.Row="3"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding LoadCommand}">
            <CollectionView ItemsSource="{Binding Projects}"
                            SelectionMode="None"
                            EmptyView="Henüz proje yok. + Yeni Proje ile başla.">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProjectItem">
                        <Border Stroke="LightGray" StrokeThickness="1" StrokeShape="RoundRectangle 6"
                                Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                       FontSize="16" FontAttributes="Bold" />
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding Description}"
                                       FontSize="12" TextColor="Gray" LineBreakMode="TailTruncation" />
                                <Label Grid.Row="2" Grid.Column="0" FontSize="11" TextColor="DarkSlateGray">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Durum: " />
                                            <Span Text="{Binding Status}" FontAttributes="Bold" />
                                            <Span Text="    Görev: " />
                                            <Span Text="{Binding TaskCount}" />
                                            <Span Text="    Üye: " />
                                            <Span Text="{Binding MemberCount}" />
                                            <Span Text="    Sahip: " />
                                            <Span Text="{Binding OwnerUserName}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <VerticalStackLayout Grid.RowSpan="3" Grid.Column="1" Spacing="4">
                                    <Button Text="Görevler" FontSize="11" Padding="8,4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProjectsViewModel}}, Path=OpenProjectCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Üyeler" FontSize="11" Padding="8,4"
                                            BackgroundColor="DarkSlateBlue" TextColor="White"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProjectsViewModel}}, Path=ManageMembersCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Düzenle" FontSize="11" Padding="8,4"
                                            BackgroundColor="LightSlateGray" TextColor="White"
                                            IsVisible="{Binding IsOwner}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProjectsViewModel}}, Path=EditProjectCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Sil" FontSize="11" Padding="8,4"
                                            BackgroundColor="IndianRed" TextColor="White"
                                            IsVisible="{Binding IsOwner}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProjectsViewModel}}, Path=DeleteProjectCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
