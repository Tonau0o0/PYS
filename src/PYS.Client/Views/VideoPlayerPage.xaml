<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PYS.Client.ViewModels"
             x:Class="PYS.Client.Views.VideoPlayerPage"
             x:DataType="vm:VideoPlayerViewModel"
             Title="Video">

    <Grid RowDefinitions="*,Auto" Padding="8" RowSpacing="8">
        <WebView Grid.Row="0" Source="{Binding EmbedUrl}" />
        <Button Grid.Row="1" Text="← Geri" Command="{Binding BackCommand}"
                BackgroundColor="LightGray" TextColor="Black" />
    </Grid>
</ContentPage>
