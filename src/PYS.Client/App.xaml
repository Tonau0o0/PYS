<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:PYS.Client.Converters"
             xmlns:local="clr-namespace:PYS.Client"
             x:Class="PYS.Client.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <conv:NullableHasValueConverter x:Key="NullableHasValueConverter" />
            <conv:StringToColorConverter x:Key="StringToColorConverter" />
            <conv:InitialsConverter x:Key="InitialsConverter" />
            <conv:ApiUrlConverter x:Key="ApiUrlConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
